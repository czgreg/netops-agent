# ========== Text Model ==========
AI_PROVIDER=zhipu
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AI_TEXT_MODEL=glm-4.7
AUTO_SELECT_TEXT_MODEL=false
ZHIPU_API_KEY=

# ========== Vision Model ==========
AI_VISION_BASE_URL=https://api.ppio.com/openai
AI_VISION_MODEL=qwen/qwen3-vl-235b-a22b-thinking
AI_VISION_FALLBACK_MODEL=
PPIO_API_KEY=

# ========== Optional Device Defaults ==========
START_DEVICE=10.0.0.11
PROTOCOL=telnet
DEVICE_TYPE=cisco_ios
NETPILOT_PORT=
NETPILOT_USERNAME=
NETPILOT_PASSWORD=
NETPILOT_ENABLE_PASSWORD=
